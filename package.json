{
  "name": "bendy-nav-nextjs",
  "version": "2.4.40",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "next build",
    "start": "tsx scripts/start.ts",
    "db:init": "tsx scripts/db-init.ts",
    "prisma:provider": "tsx scripts/prisma-provider.ts",
    "prisma:generate": "npm run prisma:provider && prisma generate",
    "prisma:migrate": "npm run prisma:provider && prisma migrate dev",
    "prisma:deploy": "npm run prisma:provider && prisma migrate deploy",
    "prisma:push": "npm run prisma:provider && prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "node -e \"const fs=require('fs');try{fs.rmSync('tsconfig.tsbuildinfo',{force:true});}catch{}\" && tsc --noEmit -p tsconfig.typecheck.json",
    "check:encoding": "node --experimental-vm-modules scripts/check-encoding.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.645.0",
    "@prisma/client": "^5.22.0",
    "@types/adm-zip": "^0.5.7",
    "@upstash/redis": "^1.34.3",
    "adm-zip": "^0.5.16",
    "cheerio": "^1.1.2",
    "jose": "^6.2.2",
    "mime-types": "^2.1.35",
    "next": "^15.5.0",
    "nodemailer": "^7.0.7",
    "postgres": "^3.4.7",
    "qs": "^6.14.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.17.2",
    "@types/nodemailer": "^7.0.1",
    "@types/qs": "^6.14.0",
    "@types/react": "19.2.14",
    "@vitest/coverage-v8": "^4.1.4",
    "prisma": "^5.22.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
