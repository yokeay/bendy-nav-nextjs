// Bendy Nav — Prisma schema
// Dual-DB via env: DATABASE_PROVIDER = postgresql | sqlite
// All tables use business prefix `bendy_` via @@map.

generator client {
  provider = "prisma-client-js"
}

// NOTE: `provider` is rewritten by scripts/prisma-provider.ts based on
// DATABASE_PROVIDER env (postgresql | sqlite) before generate/migrate/push.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Identity ----------

enum Role {
  user
  admin
  superadmin
}

enum UserStatus {
  active
  disabled
}

model User {
  id          String     @id @default(cuid())
  githubId    String     @unique
  email       String     @unique
  login       String
  name        String?
  avatarUrl   String?
  role        Role       @default(user)
  status      UserStatus @default(active)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  lastLoginAt DateTime?
  deletedAt   DateTime?

  sessions    Session[]
  auditLogs   AuditLog[]  @relation("AuditActor")
  pages       Page[]
  links       Link[]
  folders     LinkFolder[]
  docks       Dock[]
  setting     Setting?
  userEngines UserSearchEngine[]
  todos       PluginTodo[]
  todoFolders PluginTodoFolder[]
  categories  Category[]

  @@index([email])
  @@map("bendy_user")
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  jti        String    @unique
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bendy_session")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  payload    Json?
  ip         String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("bendy_audit_log")
}

// ---------- Categories ----------

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String?
  color     String?
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  links   Link[]
  bookmarks Bookmark[]

  @@index([userId])
  @@map("bendy_category")
}

// ---------- Home Content ----------

model Page {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String?
  pageType  String   @default("normal")
  sort      Int      @default(0)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  links   Link[]
  folders LinkFolder[]

  @@index([userId])
  @@map("bendy_page")
}

model LinkFolder {
  id        String   @id @default(cuid())
  userId    String
  pageId    String
  name      String
  icon      String?
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  page  Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  links Link[]

  @@index([userId])
  @@index([pageId])
  @@map("bendy_link_folder")
}

model Link {
  id          String   @id @default(cuid())
  userId      String
  pageId      String?
  folderId    String?
  categoryId  String?
  name        String
  url         String
  icon        String?
  bgColor     String?
  iconBg      Boolean  @default(false)
  app         Int      @default(0)
  size        String   @default("1x1")
  sort        Int      @default(0)
  meta        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  page     Page?       @relation(fields: [pageId], references: [id], onDelete: SetNull)
  folder   LinkFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  category Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([pageId])
  @@index([folderId])
  @@index([categoryId])
  @@map("bendy_link")
}

// Unified bookmark table used by browser-extension import, Google Chrome /
// Edge / Firefox / Safari Netscape bookmarks.html import, and manual entry.
// One row = one bookmark. Columns are deliberately flat so imports from any
// source land in a consistent shape. Anything that does not fit is stashed
// in `meta` to keep the column count bounded.
model Bookmark {
  id                   String   @id @default(cuid())
  userId               String
  categoryId           String?
  extBookmarkId        String?
  url                  String
  title                String
  folderPath           String?
  tags                 String?
  lang                 String?
  pageTitle            String?
  pageDescription      String?
  pageText             String?
  generatedTitle       String?
  generatedDescription String?
  crawlError           String?
  iconUrl              String?
  iconData             String?
  thumbnailUrl         String?
  addDate              DateTime?
  lastModifiedAt       DateTime?
  lastVisitedAt        DateTime?
  isPrivate            Boolean  @default(false)
  source               String   @default("manual")
  sourceBatchId        String?
  sourceMeta           Json?
  isRecommended        Boolean  @default(false)
  recommendTitle       String?
  recommendDesc        String?
  recommendSort        Int      @default(0)
  recommendedAt        DateTime?
  recommendedBy        String?
  isPublic             Boolean  @default(false)
  status               String   @default("active")
  sort                 Int      @default(0)
  meta                 Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime?

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([url])
  @@index([categoryId])
  @@index([isRecommended, recommendSort])
  @@index([isPublic, createdAt])
  @@index([status])
  @@map("bendy_bookmark")
}

model Dock {
  id        String   @id @default(cuid())
  userId    String
  name      String
  url       String
  icon      String?
  sort      Int      @default(0)
  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bendy_dock")
}

model Setting {
  userId    String   @id
  config    Json
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bendy_setting")
}

// ---------- Search ----------

model SearchEngine {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  url       String
  icon      String?
  sort      Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBindings UserSearchEngine[]

  @@map("bendy_search_engine")
}

model UserSearchEngine {
  userId   String
  engineId String
  sort     Int    @default(0)
  enabled  Boolean @default(true)

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  engine SearchEngine @relation(fields: [engineId], references: [id], onDelete: Cascade)

  @@id([userId, engineId])
  @@map("bendy_user_search_engine")
}

// ---------- Wallpaper ----------

model Wallpaper {
  id          String   @id @default(cuid())
  name        String   @default("")
  url         String
  hdUrl       String?
  description String?
  colorMode   String   @default("day")
  category    String   @default("default")
  sort        Int      @default(0)
  uploadedBy  String?
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([colorMode])
  @@map("bendy_wallpaper")
}

// ---------- Default home template (admin-published) ----------

model DefaultTemplate {
  id          String   @id @default(cuid())
  version     String   @unique
  content     Json
  publishedAt DateTime @default(now())
  publishedBy String?
  notes       String?

  @@map("bendy_default_template")
}

// ---------- System config (single-row style) ----------

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("bendy_system_config")
}

// ---------- Plugin: todo（占位，保留插件位） ----------

model PluginTodoFolder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos PluginTodo[]

  @@index([userId])
  @@map("bendy_plugin_todo_folder")
}

model PluginTodo {
  id        String   @id @default(cuid())
  userId    String
  folderId  String?
  content   String
  done      Boolean  @default(false)
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder PluginTodoFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
  @@map("bendy_plugin_todo")
}

// ---------- Cards: user-submitted, admin-reviewed mini web apps ----------
// host:   iframe | window | inline (runtime host type)
// status: draft | submitted | reviewing | approved | rejected | deprecated
// permissions / tags stored as Json arrays of strings for SQLite compat.

model BendyCard {
  id                     String    @id @default(cuid())
  slug                   String    @unique
  name                   String
  nameEn                 String?
  tips                   String    @default("")
  description            String    @default("")
  icon                   String    @default("")
  coverUrl               String?
  host                   String    @default("iframe")
  entryUrl               String    @default("")
  size                   String    @default("2x4")
  resizable              Boolean   @default(false)
  permissions            Json?
  sandbox                String    @default("allow-scripts allow-forms")
  contentSecurityPolicy  String?
  schemaVersion          Int       @default(1)
  inlineSource           String?
  tags                   Json?
  version                String    @default("1.0.0")
  changelog              String?
  status                 String    @default("approved")
  isFeatured             Boolean   @default(false)
  installNum             Int       @default(0)
  authorId               String?
  authorName             String?
  authorContact          String?
  publishedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  submissions BendyCardSubmission[]

  @@index([status, isFeatured])
  @@index([slug])
  @@map("bendy_card")
}

model BendyCardSubmission {
  id                     String    @id @default(cuid())
  cardId                 String?
  slug                   String
  name                   String
  nameEn                 String?
  tips                   String    @default("")
  description            String    @default("")
  icon                   String    @default("")
  coverUrl               String?
  host                   String    @default("iframe")
  entryUrl               String    @default("")
  size                   String    @default("2x4")
  resizable              Boolean   @default(false)
  permissions            Json?
  sandbox                String    @default("allow-scripts allow-forms")
  contentSecurityPolicy  String?
  schemaVersion          Int       @default(1)
  inlineSource           String?
  tags                   Json?
  version                String    @default("1.0.0")
  changelog              String?
  status                 String    @default("submitted")
  rejectReason           String?
  action                 String    @default("submit")
  reviewerId             String?
  reviewerNote           String?
  authorId               String
  authorName             String?
  authorContact          String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  reviewedAt             DateTime?

  card BendyCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([authorId])
  @@index([slug])
  @@map("bendy_card_submission")
}
