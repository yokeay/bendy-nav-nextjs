# --- Core ---
PORT=3000
BUSINESS_PREFIX=bendy
APP_BASE_URL=http://127.0.0.1:3000

# --- Database (Prisma) ---
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://username:password@host:5432/bendy?sslmode=require
# SQLite sample:
# DATABASE_PROVIDER=sqlite
# DATABASE_URL=file:./runtime/bendy.db

# --- Cache ---
CACHE_DRIVER=memory
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Storage ---
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./runtime/uploads
STORAGE_LOCAL_PUBLIC_BASE_URL=/uploads
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# --- GitHub OAuth ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_PATH=/api/auth/github/callback

# --- Admin ---
ADMIN_GITHUB_EMAILS=

# --- Session ---
SESSION_JWT_SECRET=
SESSION_ACCESS_TTL=900
SESSION_REFRESH_TTL=1209600

# --- Backup (optional) ---
BACKUP_ENABLED=false
BACKUP_CRON=0 3 * * *
BACKUP_TARGET=local

# --- Misc ---
DEMO_MODE=false
